$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 500, Height: 600);

    #Title {
      Label #TitleText {
        Text: "CLASSEMENT";
        Style: (
          ...$C.@TitleStyle,
          HorizontalAlignment: Center,
        );
        Padding: (Horizontal: 19);
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Horizontal: 10, Top: 8, Bottom: 10);

      Group #PeriodRow {
        LayoutMode: Left;
        Anchor: (Height: 44);
        Padding: (Bottom: 6);

        TextButton #BtnAll {
          Anchor: (Width: 96, Height: 36);
          Text: "TOTAL";
          Style: $C.@SmallSecondaryTextButtonStyle;
        }

        Group { Anchor: (Width: 8); }

        TextButton #BtnDaily {
          Anchor: (Width: 120, Height: 36);
          Text: "QUOTIDIEN";
          Style: $C.@SmallSecondaryTextButtonStyle;
        }

        Group { Anchor: (Width: 8); }

        TextButton #BtnWeekly {
          Anchor: (Width: 100, Height: 36);
          Text: "HEBDO";
          Style: $C.@SmallSecondaryTextButtonStyle;
        }

        Group { Anchor: (Width: 8); }

        TextButton #BtnMonthly {
          Anchor: (Width: 108, Height: 36);
          Text: "MENSUEL";
          Style: $C.@SmallSecondaryTextButtonStyle;
        }
      }

      Group #ListScroll {
        Anchor: (Height: 340);
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Top: 4, Right: 4, Bottom: 4);

        Group #ListContainer {
          LayoutMode: Top;
        }
      }

      Group #FooterWrap {
        LayoutMode: Top;
        Anchor: (Height: 102);
        Padding: (Top: 8, Left: 2, Right: 2, Bottom: 2);
        Background: #1a2535;

        Label #FooterLabel {
          Text: "VOS STATISTIQUES :";
          Anchor: (Height: 22);
          Style: (
            ...$C.@DefaultLabelStyle,
            RenderBold: true,
            TextColor: #ffffff,
          );
        }

        Group { Anchor: (Height: 8); }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28);

            Group {
              LayoutMode: Middle;
              Anchor: (Height: 28);
              Label #SelfRankKey {
                Text: "Rang :";
                Style: (
                  FontSize: 14,
                  TextColor: #ffffff,
                  VerticalAlignment: Center,
                );
              }
            }

            Group {
              LayoutMode: Middle;
              Anchor: (Height: 28);
              Label #SelfRankValue {
                Text: "";
                Style: (
                  FontSize: 14,
                  TextColor: #E8A93B,
                  RenderBold: true,
                  VerticalAlignment: Center,
                );
              }
            }
          }

          Group { Anchor: (Width: 20); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 28);

            Group {
              LayoutMode: Middle;
              Anchor: (Height: 28);
              Label #SelfTimeKey {
                Text: "Temps : ";
                Style: (
                  FontSize: 14,
                  TextColor: #ffffff,
                  VerticalAlignment: Center,
                );
              }
            }

            Group {
              LayoutMode: Middle;
              Anchor: (Height: 28);
              Label #SelfTimeValue {
                Text: "";
                Style: (
                  FontSize: 15,
                  TextColor: #E8A93B,
                  RenderBold: true,
                  VerticalAlignment: Center,
                );
              }
            }
          }
        }
      }
    }
  }
}
